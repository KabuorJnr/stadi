APP_NAME="Stadi"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=stadi
DB_USERNAME=root
DB_PASSWORD=

CACHE_STORE=database
SESSION_DRIVER=database
QUEUE_CONNECTION=database

# ─── M-PESA Daraja API ────────────────────────────────
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=174379
MPESA_PASSKEY=
MPESA_CALLBACK_URL="${APP_URL}/api/mpesa/callback"
MPESA_STK_CALLBACK_URL="${APP_URL}/api/mpesa/stk-callback"
MPESA_C2B_CONFIRMATION_URL="${APP_URL}/api/mpesa/c2b/confirm"
MPESA_C2B_VALIDATION_URL="${APP_URL}/api/mpesa/c2b/validate"

# ─── SMS Gateway (Africa's Talking) ───────────────────
SMS_DRIVER=africastalking
AT_API_KEY=
AT_USERNAME=sandbox
AT_SENDER_ID=Stadi

# ─── QR / Ticket Security ─────────────────────────────
TICKET_HASH_SECRET=
QR_ENCRYPTION_KEY=

# ─── Scanner API ───────────────────────────────────────
SCANNER_API_KEY=

# ─── Stadium Configuration ─────────────────────────────
STADIUM_NAME="Raila Odinga Stadium"
STADIUM_MAX_CAPACITY=20000
STADIUM_GATE_COUNT=4
